{
  "name": "content-engine-generator",
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "bunx vite",
    "dev:api": "bun run src/server/api.ts",
    "dev:preview": "bun run src/server/preview.ts",
    "dev:lib": "bun run --watch src/index.ts",
    "build": "bunx vite build",
    "build:lib": "bun build src/index.ts --outdir dist",
    "test": "bun test",
    "lint": "bunx biome check .",
    "format": "bunx biome format . --write"
  },
  "devDependencies": {
    "@biomejs/biome": "latest",
    "@tailwindcss/vite": "^4.2.2",
    "@types/bun": "^1.3.11",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "tailwindcss": "^4.2.2",
    "typescript": "latest",
    "vite": "^8.0.2"
  },
  "dependencies": {
    "@measured/puck": "^0.20.2",
    "playwright": "^1.58.2",
    "pptxgenjs": "^4.0.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "zod": "^4.3.6"
  }
}
